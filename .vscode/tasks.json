{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: FastAPI",
      "type": "shell",
      "command": "python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: Vite",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run full stack",
      "dependsOn": ["Backend: FastAPI", "Frontend: Vite"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
